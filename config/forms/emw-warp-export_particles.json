{
    "name": "emw-warp-export_particles",
    "help": "Warp wrapper to export particle images (2D or 3D) from tilt-series for subtomogram averaging. It will run the following program:\n\n*REFERENCES*:\n[[https://warpem.github.io/warp/reference/warptools/api/tilt_series/?h=ts_export_particles#ts_export_particles][ts_export_particles]]",
    "sections": [
        {
            "label": "General",
            "params": [       
                {
                    "label": "Input", 
                    "paramClass": "Group",
                    "params": [
                        {
                            "name": "input_tomograms",
                            "label": "Input tomograms (STAR):",
                            "pattern": "",
                            "help": "Input tomograms with coordinates",
                            "paramClass": "PathParam",
                            "pointerClass": "TomogramCoordinates"
                        },
                        {
                            "name": "ts_export_particles.diameter",
                            "label": "Particle diameter (A)",
                            "paramClass": "FloatParam",
                            "help": "REQUIRED Particle diameter in Angstroms"
                        }
                    ]
                },
                {
                    "label": "Output", 
                    "paramClass": "Group",
                    "params": [
                        {
                            "label": "Output",
                            "paramClass": "Line",
                            "params": [
                                {
                                    "name": "ts_export_particles.output_angpix",
                                    "label": "Pixel size",
                                    "paramClass": "FloatParam",
                                    "help": "REQUIRED Pixel size at which to export particles"
                                },
                                {
                                    "name": "ts_export_particles.box",
                                    "label": "Box size",
                                    "paramClass": "FloatParam",
                                    "help": "REQUIRED Output has this many pixels/voxels on each side"
                                }
                            ]
                        },                        
                        {
                            "name": "ts_export_type",
                            "label": "Export type: ",
                            "paramClass": "EnumParam",
                            "choices": ["2d", "3d"],
                            "display": "combo"
        
                        }
                    ]
                },                 
                {
                    "name": "gpus",
                    "label": "GPUs",  
                    "default": 1,
                    "paramClass": "IntParam",
                    "condition": "false",                  
                    "help": "Always use only one GPU"
                }                
            ]
    },
    {
        "label": "Filters", 
        "params": [
            {
                "label": "Particles Count",
                "paramClass": "Line",
                "help": "Ignore Tomograms with particles count outside the range.",
                "params": [
                    {
                        "name": "filters.particles_min",
                        "label": "min",
                        "default": 0,
                        "paramClass": "IntParam"
                    },
                    {
                        "name": "filters.particles_max",
                        "label": "max",
                        "default": 10000,
                        "paramClass": "IntParam"
                    }
                ]
            }                      
        ]
    }
    ]    
                
}